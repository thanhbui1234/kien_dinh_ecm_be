datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. PHÂN HỆ QUẢN TRỊ VIÊN (ADMIN AUTH)
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName     String
  role         String   @default("EDITOR") // SUPER_ADMIN, EDITOR
  refreshToken String?  // Lưu trữ Token refresh (đã băm) để có thể thu hồi khi logout
  createdAt    DateTime @default(now())
}

// ==========================================
// 2. PHÂN HỆ DANH MỤC ĐA CẤP (RECURSIVE CATEGORY)
// ==========================================
model Category {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  orderIndex      Int               @default(0)
  status          Boolean           @default(true)
  parentId        String?
  parent          Category?         @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Restrict)
  subCategories   Category[]        @relation("CategoryToCategory")
  products        Product[]
  projectMappings ProjectCategory[]
}

// ==========================================
// 3. PHÂN HỆ SẢN PHẨM & CHI TIẾT (VERTICAL PARTITIONING + JSONB)
// ==========================================
model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  price           Float? // Nếu null hoặc bằng 0 -> Hiển thị "Liên hệ báo giá"
  thumbnailUrl    String // Lưu ảnh đại diện trực tiếp để tăng tốc độ quét list ngoài Frontend
  isFeatured      Boolean          @default(false)
  status          Boolean          @default(true)
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  detail          ProductDetail? // Liên kết 1-1 sang bảng chứa hàng nặng kỹ thuật
  images          ProductImage[]
  contactRequests ContactRequest[]
  projectMappings ProjectProduct[]
  createdAt       DateTime         @default(now())

  @@index([name])
  @@index([categoryId, status])
}

model ProductDetail {
  productId      String  @id
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  contentDetail  String  @db.Text // Nội dung mô tả chi tiết bằng bài viết HTML dài
  specifications Json // Lưu cấu trúc thông số động dạng JSONB linh hoạt cho máy CNC
}

model ProductImage {
  id         String  @id @default(uuid())
  imageUrl   String
  isMain     Boolean @default(false)
  orderIndex Int     @default(0)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ==========================================
// 4. PHÂN HỆ ĐỐI TÁC DỰ ÁN (MANY-TO-MANY MAPPING)
// ==========================================
model Project {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String            @db.VarChar(500)
  coverImage  String
  status      Boolean           @default(true)
  detail      ProjectDetail?
  products    ProjectProduct[]
  categories  ProjectCategory[]
  createdAt   DateTime          @default(now())
}

model ProjectDetail {
  projectId     String  @id
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentDetail String  @db.Text
}

model ProjectProduct {
  projectId String
  productId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([projectId, productId])
}

model ProjectCategory {
  projectId  String
  categoryId String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([projectId, categoryId])
}

// ==========================================
// 5. PHÂN HỆ TIẾP NHẬN LEAD KHÁCH HÀNG (LEAD GENERATION)
// ==========================================
model ContactRequest {
  id              String   @id @default(uuid())
  fullName        String
  phoneNumber     String
  email           String?
  message         String   @db.Text
  status          String   @default("PENDING") // PENDING, CONTACTED, SPAM
  adminNote       String?  @db.Text
  targetProductId String?
  product         Product? @relation(fields: [targetProductId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
}

// ==========================================
// 6. PHÂN HỆ TUYỂN DỤNG CÔNG NGHIỆP (RECRUITMENT 1-1 SPLIT)
// ==========================================
model JobPost {
  id        String         @id @default(uuid())
  title     String
  slug      String         @unique
  salary    String         @default("Cạnh tranh")
  status    Boolean        @default(true)
  detail    JobPostDetail?
  createdAt DateTime       @default(now())
}

model JobPostDetail {
  jobId       String  @id
  jobPost     JobPost @relation(fields: [jobId], references: [id], onDelete: Cascade)
  description String  @db.Text // Mô tả công việc (Job Description)
  requirement String  @db.Text // Yêu cầu bằng cấp, kỹ năng máy CNC
}

// ==========================================
// 7. CẤU HÌNH HỆ THỐNG & TRANG ABOUT US DYNAMIC
// ==========================================
model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique // hotline, zalo_url, hr_email
  value String @db.Text
}

model CompanySlogan {
  id         String @id @default(uuid())
  title      String
  icon       String // Tên định danh Icon (Lucide/FontAwesome)
  orderIndex Int    @default(0)
}

model CompanyTimeline {
  id          String @id @default(uuid())
  year        String // 2005, 2010, 2015
  title       String
  description String @db.Text
  orderIndex  Int    @default(0)
}
