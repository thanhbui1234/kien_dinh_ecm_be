generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  fullName     String
  role         String   @default("EDITOR")
  createdAt    DateTime @default(now())
  refreshToken String?
}

model Category {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  orderIndex      Int               @default(0)
  status          Boolean           @default(true)
  parentId        String?
  imageUrl        String?
  parent          Category?         @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Restrict)
  subCategories   Category[]        @relation("CategoryToCategory")
  products        Product[]
  projectMappings ProjectCategory[]

  @@index([parentId])
  @@index([orderIndex])
}

model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  price           Float?
  thumbnailUrl    String
  isFeatured      Boolean          @default(false)
  status          Boolean          @default(true)
  categoryId      String
  createdAt       DateTime         @default(now())
  parentId        String?
  viewCount       Int              @default(0)
  contactRequests ContactRequest[]
  category        Category         @relation(fields: [categoryId], references: [id])
  parent          Product?         @relation("ProductVariants", fields: [parentId], references: [id], onDelete: Restrict)
  variants        Product[]        @relation("ProductVariants")
  detail          ProductDetail?
  images          ProductImage[]
  projectMappings ProjectProduct[]

  @@index([name])
  @@index([categoryId, status])
  @@index([isFeatured, status])
}

model ProductDetail {
  productId      String  @id
  contentDetail  String
  specifications Json
  seoMeta        Json?
  features       Json?
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id         String  @id @default(uuid())
  imageUrl   String
  isMain     Boolean @default(false)
  orderIndex Int     @default(0)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Project {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String            @db.VarChar(500)
  coverImage  String
  status      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  isFeatured  Boolean           @default(false)
  categories  ProjectCategory[]
  detail      ProjectDetail?
  products    ProjectProduct[]

  @@index([status, createdAt(sort: Desc)])
  @@index([isFeatured, status])
}

model ProjectDetail {
  projectId     String   @id
  contentDetail String
  images        String[] @default([])
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectProduct {
  projectId String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, productId])
}

model ProjectCategory {
  projectId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, categoryId])
}

model ContactRequest {
  id              String       @id @default(uuid())
  fullName        String
  phoneNumber     String
  email           String?
  message         String
  status          String       @default("PENDING")
  adminNote       String?
  targetProductId String?
  createdAt       DateTime     @default(now())
  priority        LeadPriority @default(MEDIUM)
  product         Product?     @relation(fields: [targetProductId], references: [id])

  @@index([status, createdAt(sort: Desc)])
}

model JobPost {
  id        String         @id @default(uuid())
  title     String
  slug      String         @unique
  salary    String         @default("Cạnh tranh")
  status    Boolean        @default(true)
  createdAt DateTime       @default(now())
  detail    JobPostDetail?

  @@index([status, createdAt(sort: Desc)])
}

model JobPostDetail {
  jobId     String   @unique
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  sections  Json
  updatedAt DateTime @updatedAt
  job       JobPost  @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model CompanyInfo {
  id         String @id @default(uuid())
  label      String
  value      String
  orderIndex Int    @default(0)

  @@index([orderIndex])
}

model Facility {
  id         String  @id @default(uuid())
  region     String
  country    String
  name       String
  address    String
  phone      String
  imageUrl   String?
  orderIndex Int     @default(0)

  @@index([orderIndex])
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model CompanySlogan {
  id          String  @id @default(uuid())
  title       String
  icon        String
  orderIndex  Int     @default(0)
  description String?

  @@index([orderIndex])
}

model CompanyTimeline {
  id          String @id @default(uuid())
  year        String
  title       String
  description String
  orderIndex  Int    @default(0)

  @@index([orderIndex])
}

model Banner {
  id          String   @id @default(uuid())
  imageUrl    String
  orderIndex  Int      @default(0)
  status      Boolean  @default(true)
  createdAt   DateTime @default(now())
  description String?
  link        String?
  title       String?

  @@index([status, orderIndex])
}

model CompanyProfile {
  id        String @id @default("singleton")
  introHtml String @default("")
}

model CompanyHistoryEvent {
  id         String   @id @default(uuid())
  period     String
  year       String
  text       String
  imageUrl   String?
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([period, orderIndex])
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}
